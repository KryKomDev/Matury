{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "informatika/assets/**",
          "informatika/ulohy/texty/**",
          "informatika/ulohy/web/**",
          "gl.png"
        ],
        "exclude": [
          "**/*.md",
          "**/*.yml"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/dokfx"
    ],
    "globalMetadata": {
      "_appName": "Matury",
      "_appTitle": "Matury",
      "_gitRepo": "https://github.com/KryKomDev/Metriks",
      "_appLogoPath": "gl.png",
      "_appFaviconPath": "gl.png",
      "_enableSearch": true,
      "pdf": false,
      "_appFooter": "<span>Copyright &copy; 2026-2027 <a href='https://github.com/KryKomDev/Matury/blob/main/AUTHORS.md' target='_blank'>Autoři</a> · Licencováno pod CC-BY-SA 4.0 · Zdrojový kód na <a href='https://github.com/KryKomDev/Matury' target='_blank'>GitHub</a> · Generováno pomocí <a href='https://dotnet.github.io/docfx/' target='_blank'>DocFX</a> s šablonou <a href='https://github.com/KryKomDev/Dokfx' target='_blank'>Dokfx</a></span>"
    }
  }
}